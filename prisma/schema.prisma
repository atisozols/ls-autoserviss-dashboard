generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Settings {
  id                  Int      @id @default(1)
  laborRate           Decimal  @default(35) @db.Decimal(10, 2)
  employeeHourlyCost  Decimal  @default(8) @db.Decimal(10, 2)
  electricityCost     Decimal  @default(0) @db.Decimal(10, 2)
  rentCost            Decimal  @default(0) @db.Decimal(10, 2)
  heatCost            Decimal  @default(0) @db.Decimal(10, 2)
  cleaningCost        Decimal  @default(0) @db.Decimal(10, 2)
  clothingCost        Decimal  @default(0) @db.Decimal(10, 2)
  updatedAt           DateTime @updatedAt
}

model Worker {
  id           String   @id @default(cuid())
  name         String
  monthlyRate  Decimal  @default(0) @db.Decimal(10, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  jobs         Job[]

  @@index([name])
}

model Job {
  id                 String    @id @default(cuid())
  date               DateTime
  plateNumber        String
  clientName         String?
  clientPhone        String?
  vehicleNote        String?
  additionalExpenses Decimal   @default(0) @db.Decimal(10, 2)
  amountPaid         Decimal   @default(0) @db.Decimal(10, 2)
  notes              String?
  workerId           String?
  worker             Worker?   @relation(fields: [workerId], references: [id], onDelete: SetNull)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  items              JobItem[]

  @@index([date(sort: Desc)])
  @@index([plateNumber])
  @@index([clientName])
  @@index([workerId])
}

model JobItem {
  id                 String   @id @default(cuid())
  jobId              String
  rowOrder           Int
  partName           String
  partCode           String?
  quantity           Decimal  @default(1) @db.Decimal(10, 2)
  partPurchasePrice  Decimal  @default(0) @db.Decimal(10, 2)
  partSalePrice      Decimal  @default(0) @db.Decimal(10, 2)
  laborHours         Decimal  @default(0) @db.Decimal(10, 2)
  laborRate          Decimal  @default(35) @db.Decimal(10, 2)
  employeeHourlyCost Decimal  @default(8) @db.Decimal(10, 2)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  job                Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, rowOrder])
  @@index([partName])
  @@index([partCode])
}
